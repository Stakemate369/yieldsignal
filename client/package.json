{
  "name": "yieldsignal-client",
  "version": "1.0.0",
  "description": "Thin x402 client for YieldSignal — risk-weighted USDC/WETH lending APY across Aave, Compound, Morpho, Moonwell, Euler and Fluid on Base.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "prepublishOnly": "npm run build"
  },
  "keywords": ["x402", "yield", "defi", "base", "agent", "mcp"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Stakemate369/yieldsignal.git",
    "directory": "client"
  },
  "homepage": "https://yieldsignal.vercel.app",
  "dependencies": {
    "@x402/fetch": "^2.18.0",
    "viem": "^2.21.54"
  },
  "devDependencies": {
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  }
}
