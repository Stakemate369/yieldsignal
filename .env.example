# Credenciais CDP PRÓPRIAS deste projeto — gere um par NOVO no portal da CDP,
# NÃO reaproveite as do YieldPilot. Estas 3 variáveis são usadas pelo
# createX402Server() pra provisionar automaticamente a carteira que recebe
# os pagamentos x402 — não existe endereço configurado à mão aqui.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_WALLET_SECRET=

# "development" liquida em base-sepolia (dinheiro de teste) — use isto pra
# ensaiar o fluxo de pagamento ANTES de trocar pra "production" (base mainnet,
# dinheiro real).
X402_ENVIRONMENT=development

# Carteira pessoal (a mesma que você usa no YieldPilot ou outra, sua escolha)
# — único destino permitido pelo comando `npm run withdraw`.
OWNER_WALLET_ADDRESS=

PORT=4021
PRICE_USD=$0.01
LOG_LEVEL=info

# Preenchido depois de rodar `npm run register-schema` uma vez (mainnet,
# gasta ETH real de gas) — vazio desliga só `npm run attest`, resto do
# produto funciona normalmente sem isso.
EAS_SCHEMA_UID=
